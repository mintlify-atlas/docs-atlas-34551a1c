  "keyFeatures": [
    "Fine-grained reactivity for minimal re-renders",
    "Super fast performance (4kb bundle size)",
    "Observable state management with get/set API",
    "React hooks and components for reactive UIs",
    "Automatic persistence with local and remote sync",
    "Type-safe TypeScript support",
    "Computed observables and linked state",
    "Batching for optimized updates",
    "Local-first sync with conflict resolution",
    "Persistence plugins (localStorage, IndexedDB, AsyncStorage, MMKV)",
    "Sync plugins (Keel, Supabase, Firebase, TanStack Query)",
    "React Native support",
    "Undo/redo functionality",
    "Middleware system for extending behavior"
  ],
  "publicApiSurface": [
    "observable() - Create observable state",
    "observe() - React to state changes",
    "computed() - Derived computed values",
    "batch() - Batch multiple updates",
    "when() - Wait for conditions",
    "useObservable() - React hook for local state",
    "useSelector() - React hook for derived state",
    "useObserve() - React hook for side effects",
    "observer() - HOC for reactive components",
    "Memo - Reactive memo component",
    "For - Reactive list rendering",
    "Show - Conditional rendering",
    "Switch - Multi-conditional rendering",
    "Reactive - Reactive props wrapper",
    "synced() - Create synced observable",
    "syncObservable() - Sync existing observable",
    "persistObservable plugins - localStorage, IndexedDB, AsyncStorage, MMKV",
    "sync plugins - Keel, Supabase, Firebase, TanStack Query, fetch",
    "linked() - Create linked observables",
    "proxy() - Create proxy observables",
    "configureReactive() - Configure reactive components",
    "enableReactTracking() - Enable automatic React tracking",
    "trackHistory() - Track state changes",
    "undoRedo() - Undo/redo functionality"
  ]
